{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "code-review",
  "type": "object",
  "required": ["title", "files"],
  "properties": {
    "title": { "type": "string" },
    "subtitle": { "type": "string" },
    "block_id": { "type": "string" },
    "prompt_intro": { "type": "string" },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "code"],
        "properties": {
          "id": { "type": "string" },
          "path": { "type": "string" },
          "language": { "type": "string" },
          "code": { "type": "string", "description": "Lines prefixed with '+ ' for added, '- ' for removed; otherwise context." },
          "start_line": { "type": "number" },
          "diff": { "type": "boolean" },
          "comments": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["line", "body"],
              "properties": {
                "line": { "type": "number" },
                "body": { "type": "string" },
                "author": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
