{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "checklist",
  "type": "object",
  "required": ["title", "items"],
  "properties": {
    "title": { "type": "string" },
    "subtitle": { "type": "string" },
    "block_id": { "type": "string" },
    "prompt_intro": { "type": "string" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "note": { "type": "string" },
          "done": { "type": "boolean" },
          "owner": { "type": "string" },
          "due": { "type": "string" },
          "priority": { "type": "string", "enum": ["low", "med", "high"] },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
