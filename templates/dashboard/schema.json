{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "dashboard",
  "type": "object",
  "required": ["title", "metrics"],
  "properties": {
    "title": { "type": "string" },
    "subtitle": { "type": "string" },
    "updated_at": { "type": "string" },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["label", "value"],
        "properties": {
          "label": { "type": "string" },
          "value": {},
          "delta": { "type": "number" },
          "trend": { "type": "array", "items": { "type": "number" } },
          "target": {},
          "format": { "type": "string", "enum": ["number", "currency", "percent"] }
        }
      }
    }
  }
}
