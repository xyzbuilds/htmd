{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "prompt-tuner",
  "type": "object",
  "required": ["prompt_template", "variables", "samples"],
  "properties": {
    "title": { "type": "string" },
    "description": { "type": "string" },
    "prompt_template": { "type": "string" },
    "variables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "default": { "type": "string" }
        }
      }
    },
    "samples": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["name", "vars"],
        "properties": {
          "name": { "type": "string" },
          "vars": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      }
    }
  }
}
