{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "kanban-board",
  "type": "object",
  "required": ["columns", "tickets"],
  "properties": {
    "title": { "type": "string" },
    "subtitle": { "type": "string" },
    "columns": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["key", "name"],
        "properties": {
          "key": { "type": "string" },
          "name": { "type": "string" }
        }
      }
    },
    "tickets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "column"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "body": { "type": "string" },
          "owner": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "column": { "type": "string" }
        }
      }
    }
  }
}
