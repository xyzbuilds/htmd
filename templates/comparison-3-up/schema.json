{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "comparison-3-up",
  "type": "object",
  "required": ["title", "approaches"],
  "properties": {
    "title": { "type": "string" },
    "subtitle": { "type": "string" },
    "approaches": {
      "type": "array",
      "minItems": 2,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "summary": { "type": "string" },
          "pros": { "type": "array", "items": { "type": "string" } },
          "cons": { "type": "array", "items": { "type": "string" } },
          "when_to_use": { "type": "string" },
          "code": { "type": "string" }
        }
      }
    },
    "verdict": { "type": "string" }
  }
}
