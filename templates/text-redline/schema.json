{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "text-redline",
  "type": "object",
  "required": ["title", "segments"],
  "properties": {
    "title": { "type": "string" },
    "subtitle": { "type": "string" },
    "block_id": { "type": "string" },
    "prompt_intro": { "type": "string" },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" },
          "note": { "type": "string" },
          "locked": { "type": "boolean" }
        }
      }
    }
  }
}
