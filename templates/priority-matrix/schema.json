{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "priority-matrix",
  "type": "object",
  "required": ["title", "items"],
  "properties": {
    "title": { "type": "string" },
    "subtitle": { "type": "string" },
    "block_id": { "type": "string" },
    "prompt_intro": { "type": "string" },
    "quadrants": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["id", "label"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "hint": { "type": "string" }
        }
      }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "quadrant": { "type": "string" }
        }
      }
    }
  }
}
