{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "feedback-corrector",
  "type": "object",
  "required": ["title", "labels", "items"],
  "properties": {
    "title": { "type": "string" },
    "subtitle": { "type": "string" },
    "labels": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["value", "label"],
        "properties": {
          "value": { "type": "string" },
          "label": { "type": "string" },
          "color": { "type": "string" },
          "emoji": { "type": "string" }
        }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "current_label"],
        "properties": {
          "id": { "type": "string" },
          "current_label": { "type": "string" },
          "title": { "type": "string" },
          "subtitle": { "type": "string" },
          "body": { "type": "string" },
          "metadata": { "type": "object" },
          "verdict_reason": { "type": "string" }
        }
      }
    },
    "prompt_intro": {
      "type": "string",
      "description": "Text prepended to the exported correction prompt"
    },
    "prompt_template": {
      "type": "string",
      "description": "Optional override for the exported prompt format. Tokens: {intro} {context_id} {date} {items}"
    },
    "context_id": {
      "type": "string",
      "description": "Identifier for the source system (e.g., 'gmail-triage') so corrections can be routed back"
    }
  }
}
