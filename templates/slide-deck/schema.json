{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "slide-deck",
  "type": "object",
  "required": ["title", "slides"],
  "properties": {
    "title": { "type": "string" },
    "theme": { "type": "string" },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "body_md": { "type": "string" },
          "image": { "type": "string" },
          "code": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
