{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "q-and-a",
  "type": "object",
  "required": ["title", "questions"],
  "properties": {
    "title": { "type": "string" },
    "subtitle": { "type": "string" },
    "block_id": { "type": "string" },
    "prompt_intro": { "type": "string" },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["prompt"],
        "properties": {
          "id": { "type": "string" },
          "prompt": { "type": "string" },
          "context": { "type": "string" },
          "kind": { "type": "string", "enum": ["free", "single", "multi"] },
          "choices": {
            "type": "array",
            "items": {
              "oneOf": [
                { "type": "string" },
                {
                  "type": "object",
                  "required": ["label"],
                  "properties": {
                    "value": { "type": "string" },
                    "label": { "type": "string" }
                  }
                }
              ]
            }
          },
          "default_answer": {},
          "placeholder": { "type": "string" }
        }
      }
    }
  }
}
